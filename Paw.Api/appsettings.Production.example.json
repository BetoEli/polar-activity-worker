    "https://qep.yourdomain.com",
    "https://yourdomain.com"
  ],
  "QepApiKey": "GENERATE_RANDOM_SECURE_KEY_MIN_32_CHARS",
  "QepApiKeys": {
    "student": "GENERATE_RANDOM_SECURE_KEY_MIN_32_CHARS_STUDENT",
    "QepFaculty": "GENERATE_RANDOM_SECURE_KEY_MIN_32_CHARS_FACULTY",
