@model LoginViewModel
@{ Layout = null; }

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign in — Polar Activity</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: #f9f9f9;
            font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
        }
        .login-card {
            background: #fff;
            border-radius: 14px;
            box-shadow: 0 2px 16px rgba(0,0,0,.09);
            padding: 2.5rem 2rem;
            width: 100%;
            max-width: 360px;
        }
        .brand { font-weight: 700; font-size: 1.5rem; letter-spacing: -.5px; color: #111; }
        .brand span { color: #d5001c; }
        .tagline { font-size: .85rem; color: #999; margin-top: .2rem; margin-bottom: 2rem; }
        .form-label { font-size: .82rem; font-weight: 500; color: #555; }
        .form-control { border-radius: 8px; border-color: #e0e0e0; font-size: .9rem; }
        .form-control:focus { border-color: #d5001c; box-shadow: 0 0 0 3px rgba(213,0,28,.1); }
        .btn-signin {
            background: #d5001c;
            border: none;
            border-radius: 8px;
            color: #fff;
            font-size: .9rem;
            font-weight: 600;
            padding: .6rem;
            width: 100%;
            margin-top: .5rem;
        }
        .btn-signin:hover { background: #b0001a; }
        .error-msg { font-size: .82rem; color: #c0001a; background: #fff5f5; border: 1px solid #fcd0d4; border-radius: 8px; padding: .6rem .9rem; margin-bottom: 1rem; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="brand">Polar<span>.</span></div>
        <div class="tagline">Sign in to view your workouts</div>

        <form asp-action="Login" asp-controller="Account" method="post">
            <input type="hidden" asp-for="ReturnUrl" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="error-msg">
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" type="email" autocomplete="email" placeholder="you@example.com" />
            </div>

            <button type="submit" class="btn-signin">Sign in</button>
        </form>
    </div>
</body>
</html>
