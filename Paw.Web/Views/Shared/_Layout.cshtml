<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} — Polar Activity" : "Polar Activity")</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: #f9f9f9;
            font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
            color: #111;
        }
        .navbar {
            background: #fff !important;
            border-bottom: 1px solid #eee;
        }
        .navbar-brand { font-weight: 700; letter-spacing: -.5px; color: #111 !important; }
        .navbar-brand .dot { color: #d5001c; }
        .nav-link { color: #444 !important; font-size: .9rem; }
        .nav-link:hover { color: #111 !important; }
        .page-body { max-width: 840px; margin: 0 auto; padding: 2rem 1rem 4rem; }
        .card {
            background: #fff;
            border: none !important;
            box-shadow: 0 1px 5px rgba(0,0,0,.07);
            border-radius: 12px;
        }
        .stat-value { font-size: 2.2rem; font-weight: 700; line-height: 1; color: #111; }
        .stat-label {
            font-size: .7rem;
            text-transform: uppercase;
            letter-spacing: .07em;
            color: #999;
            margin-top: .3rem;
        }
        .activity-row { border-bottom: 1px solid #f2f2f2; padding: .85rem 0; }
        .activity-row:last-child { border-bottom: none; }
        .badge-zone {
            font-size: .68rem;
            background: #f0f0f0;
            color: #555;
            border-radius: 5px;
            padding: 2px 7px;
            margin-right: 3px;
            display: inline-block;
        }
        .section-title {
            font-size: .72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .09em;
            color: #aaa;
            margin-bottom: 1rem;
        }
        .btn-primary { background: #d5001c !important; border-color: #d5001c !important; }
        .btn-primary:hover { background: #b0001a !important; border-color: #b0001a !important; }
        .connect-banner {
            background: #fffbf0;
            border: 1px solid #fce9b0;
            border-radius: 10px;
            padding: 1rem 1.25rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
        }
        .connect-banner p { margin: 0; font-size: .9rem; color: #6b5000; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-md mb-0">
        <div class="container" style="max-width:840px">
            <a class="navbar-brand" href="/Dashboard">Polar<span class="dot">.</span></a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="navbar-nav ms-auto d-flex flex-row align-items-center gap-3">
                    <a class="nav-link" href="/Dashboard">Dashboard</a>
                    @if (ViewBag.HasPolarLinked == false)
                    {
                        <a class="nav-link" href="/Polar/Connect" style="color:#d5001c !important">Connect Polar</a>
                    }
                    <form method="post" action="/Account/Logout" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm" style="border:1px solid #ddd;color:#555;font-size:.85rem">Sign out</button>
                    </form>
                </div>
            }
        </div>
    </nav>

    <div class="page-body">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
