<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} — PAW" : "PAW")</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body>
    <nav class="navbar navbar-expand-md navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/Dashboard">PAW</a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="navbar-nav ms-auto d-flex flex-row align-items-center gap-3">
                    <a class="nav-link text-white" href="/Dashboard">Dashboard</a>
                    @if (ViewBag.HasPolarLinked == false)
                    {
                        <a class="nav-link text-warning" href="/Polar/Connect">Connect Polar</a>
                    }
                    <form method="post" action="/Account/Logout" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-light">Logout</button>
                    </form>
                </div>
            }
        </div>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
