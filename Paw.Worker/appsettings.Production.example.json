{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SQL_SERVER;Database=QEPTest;User Id=USERNAME;Password=PASSWORD;MultipleActiveResultSets=True;TrustServerCertificate=True;Encrypt=True;"
  },
  "Worker": {
    "PollingIntervalSeconds": 10,
    "BatchSize": 50
  },
  "Polar": {
    "ClientId": "YOUR_POLAR_CLIENT_ID",
    "ClientSecret": "YOUR_POLAR_CLIENT_SECRET",
    "RedirectUri": "https://yourdomain.com/qep/polar/callback",
    "BaseUrl": "https://www.polaraccesslink.com",
    "AuthorizationEndpoint": "https://flow.polar.com/oauth2/authorization",
    "TokenEndpoint": "https://polarremote.com/v2/oauth2/token",
    "UserRegistrationEndpoint": "https://www.polaraccesslink.com/v3/users",
    "Scope": "accesslink.read_all",
    "WebhookUrl": "https://yourdomain.com/webhooks/polar",
    "WebhookSignatureSecret": "SIGNATURE_SECRET_FROM_POLAR_WEBHOOK_SETUP",
    "EnforceWebhookSignature": true,
    "WebhooksEndpoint": "/v3/webhooks",
    "WebhooksActivateEndpoint": "/v3/webhooks/activate"
  }
}
